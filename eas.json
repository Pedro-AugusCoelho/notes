{
    "cli": {
        "version": ">= 16.0.0",
        "appVersionSource": "remote"
    },
    "build": {
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "autoIncrement": true
        },
        "production": {
            "android": {
                "buildType": "app-bundle"
            },
            "autoIncrement": true
        },
        "optimized": {
            "distribution": "internal",
            "android": {
                "buildType": "apk",
                "gradleCommand": ":app:assembleRelease"
            },
            "autoIncrement": true
        }
    }
}